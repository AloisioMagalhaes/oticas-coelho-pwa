{
  "name": "oticas-coelho-pwa",
  "version": "0.1.0",
  "description": "PWA da Óticas Coelho — Rede de óculos com 20 anos no mercado. Vendas, avaliação visual e SEO local.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src/ --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css,json,md}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun",
    "pwa:generate-icons": "pwa-asset-generator ./public/logo.svg ./public/icons --manifest ./public/manifest/manifest.json"
  },
  "dependencies": {
    "lit": "^3.1.0",
    "workbox-window": "^7.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-a11y": "^7.6.0",
    "@storybook/builder-vite": "^7.6.0",
    "@storybook/web-components": "^7.6.0",
    "@storybook/web-components-vite": "^7.6.0",
    "storybook": "^7.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "@lhci/cli": "^0.13.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0"
  },
  "keywords": [
    "pwa",
    "web-components",
    "oticas",
    "ecommerce",
    "seo",
    "lit",
    "vite",
    "storybook"
  ],
  "author": "Óticas Coelho",
  "license": "UNLICENSED"
}
